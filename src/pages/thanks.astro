---
import BaseLayout from '../layouts/BaseLayout.astro';
import settings from '../data/settings.yaml';
---
<BaseLayout title="Message Sent" seo_description="Your message has been received." hideContactForm={true}>
  <div class="thanks-hero"></div>
  <section class="thanks-section section--cream">
    <div class="container thanks-section__inner">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true" class="thanks-section__icon">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="8,12 11,15 16,9"/>
      </svg>
      <h1 class="thanks-section__heading">Message Received</h1>
      <p class="thanks-section__body">
        Thank you for reaching out. We'll be in touch soon.
      </p>
      <a href="/" class="btn btn--fill-green">Back to Home</a>
    </div>
  </section>
</BaseLayout>
