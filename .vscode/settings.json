  "editor.tokenColorCustomizations": {
    "comments": { "foreground": "#5A4030", "fontStyle": "italic" },
    "keywords": { "foreground": "#C42040", "fontStyle": "bold" },
    "strings": { "foreground": "#D4A870" },
    "numbers": { "foreground": "#C8A040" },
    "types": { "foreground": "#C8A040" },
    "functions": { "foreground": "#E0CCA8" },
    "variables": { "foreground": "#EDE8DC" },
    "textMateRules": [
      { "scope": "keyword",                    "settings": { "foreground": "#C42040", "fontStyle": "bold" } },
      { "scope": "keyword.control",            "settings": { "foreground": "#A8203A", "fontStyle": "bold" } },
      { "scope": "keyword.operator",           "settings": { "foreground": "#C4AA88", "fontStyle": "" } },
      { "scope": "storage.type",              "settings": { "foreground": "#C42040" } },
      { "scope": "storage.modifier",          "settings": { "foreground": "#A8203A" } },
      { "scope": "string",                    "settings": { "foreground": "#D4A870" } },
      { "scope": "string.template",           "settings": { "foreground": "#C49A60" } },
      { "scope": "constant.numeric",          "settings": { "foreground": "#C8A040" } },
      { "scope": "constant.language",         "settings": { "foreground": "#C42040" } },
      { "scope": "constant.character",        "settings": { "foreground": "#D4A870" } },
      { "scope": "variable",                  "settings": { "foreground": "#EDE8DC" } },
      { "scope": "variable.parameter",        "settings": { "foreground": "#E0D0B8", "fontStyle": "italic" } },
      { "scope": "variable.language",         "settings": { "foreground": "#A8203A", "fontStyle": "italic" } },
      { "scope": "entity.name.function",      "settings": { "foreground": "#E0CCA8" } },
      { "scope": "entity.name.type",          "settings": { "foreground": "#C8A040" } },
      { "scope": "entity.name.class",         "settings": { "foreground": "#C8A040" } },
      { "scope": "entity.name.tag",           "settings": { "foreground": "#C42040" } },
      { "scope": "entity.other.attribute-name","settings": { "foreground": "#D4A870" } },
      { "scope": "support.function",          "settings": { "foreground": "#D4B896" } },
      { "scope": "support.class",             "settings": { "foreground": "#C8A040" } },
      { "scope": "support.type",              "settings": { "foreground": "#C8A040" } },
      { "scope": "support.constant",          "settings": { "foreground": "#C42040" } },
      { "scope": "comment",                   "settings": { "foreground": "#5A4030", "fontStyle": "italic" } },
      { "scope": "punctuation",               "settings": { "foreground": "#907860" } },
      { "scope": "punctuation.definition.tag","settings": { "foreground": "#6A4030" } },
      { "scope": "meta.tag",                  "settings": { "foreground": "#C4AA88" } },
      { "scope": "invalid",                   "settings": { "foreground": "#FF4060", "fontStyle": "underline" } },
      { "scope": "invalid.deprecated",        "settings": { "foreground": "#C8A040", "fontStyle": "underline italic" } }
    ]
  }
}