  "editor.tokenColorCustomizations": {
    "comments": { "foreground": "#4A6448", "fontStyle": "italic" },
    "keywords": { "foreground": "#6A8A68", "fontStyle": "bold" },
    "strings": { "foreground": "#C4A860" },
    "numbers": { "foreground": "#C4973A" },
    "types": { "foreground": "#C4973A" },
    "functions": { "foreground": "#D4E4CC" },
    "variables": { "foreground": "#EEF1ED" },
    "textMateRules": [
      { "scope": "keyword",                    "settings": { "foreground": "#6A8A68", "fontStyle": "bold" } },
      { "scope": "keyword.control",            "settings": { "foreground": "#5E7A5C", "fontStyle": "bold" } },
      { "scope": "keyword.operator",           "settings": { "foreground": "#C8D4C0", "fontStyle": "" } },
      { "scope": "storage.type",              "settings": { "foreground": "#6A8A68" } },
      { "scope": "storage.modifier",          "settings": { "foreground": "#5E7A5C" } },
      { "scope": "string",                    "settings": { "foreground": "#C4A860" } },
      { "scope": "string.template",           "settings": { "foreground": "#B89850" } },
      { "scope": "constant.numeric",          "settings": { "foreground": "#C4973A" } },
      { "scope": "constant.language",         "settings": { "foreground": "#6A8A68" } },
      { "scope": "constant.character",        "settings": { "foreground": "#C4A860" } },
      { "scope": "variable",                  "settings": { "foreground": "#EEF1ED" } },
      { "scope": "variable.parameter",        "settings": { "foreground": "#D4E4CC", "fontStyle": "italic" } },
      { "scope": "variable.language",         "settings": { "foreground": "#5E7A5C", "fontStyle": "italic" } },
      { "scope": "entity.name.function",      "settings": { "foreground": "#D4E4CC" } },
      { "scope": "entity.name.type",          "settings": { "foreground": "#C4973A" } },
      { "scope": "entity.name.class",         "settings": { "foreground": "#C4973A" } },
      { "scope": "entity.name.tag",           "settings": { "foreground": "#7AAA78" } },
      { "scope": "entity.other.attribute-name","settings": { "foreground": "#C4A860" } },
      { "scope": "support.function",          "settings": { "foreground": "#C4D0BC" } },
      { "scope": "support.class",             "settings": { "foreground": "#C4973A" } },
      { "scope": "support.type",              "settings": { "foreground": "#C4973A" } },
      { "scope": "support.constant",          "settings": { "foreground": "#6A8A68" } },
      { "scope": "comment",                   "settings": { "foreground": "#4A6448", "fontStyle": "italic" } },
      { "scope": "punctuation",               "settings": { "foreground": "#7A9478" } },
      { "scope": "punctuation.definition.tag","settings": { "foreground": "#5A7858" } },
      { "scope": "meta.tag",                  "settings": { "foreground": "#C8D4C0" } },
      { "scope": "invalid",                   "settings": { "foreground": "#FF4060", "fontStyle": "underline" } },
      { "scope": "invalid.deprecated",        "settings": { "foreground": "#C4973A", "fontStyle": "underline italic" } }
    ]
  }
